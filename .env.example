# EduGenie Environment Variables
# Copy this file to .env and fill in your values

# Database (SQLite by default)
DATABASE_URL=sqlite:///./edugenie.db

# JWT Secret - REQUIRED - Generate a strong random string for production
SECRET_KEY=

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Gemini Model
GEMINI_MODEL_NAME=gemini-2.5-flash

# HuggingFace Model (for local inference)
HF_MODEL_NAME=MBZUAI/LaMini-Flan-T5-248M

# Set to True to use local HuggingFace model instead of Gemini
USE_LOCAL_MODEL=False

# Mock mode for HuggingFace (avoids downloading model in dev)
RUN_HF_MOCK=True
